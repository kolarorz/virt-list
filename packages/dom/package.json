{
  "name": "@virt-list/dom",
  "version": "0.0.1",
  "description": "DOM-based virtual list, grid and tree implementations",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./src/tree/tree.css": "./src/tree/tree.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@virt-list/core": "workspace:*"
  },
  "keywords": ["virtual-list", "virtual-tree", "virtual-grid", "dom"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicepkg/virt-list",
    "directory": "packages/dom"
  },
  "sideEffects": [
    "**/*.css"
  ]
}
