{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "types": ["vite/client"],
    "jsx": "preserve",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@virt-list/core": ["../../../packages/core/src/index.ts"],
      "@virt-list/vanilla": ["../../../packages/vanilla/src/index.ts"],
      "@virt-list/vue2": ["../../../packages/vue2/src/index.ts"]
    },
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"]
}
